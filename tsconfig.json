{
    "compilerOptions": {
        "target": "es2016",
        "lib": [
            "Decorators",
            "DOM",
            "DOM.Iterable",
            "ES2023",
            "ESNext.Decorators",
            "ESNext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "noEmit": false,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "incremental": true,
        "sourceMap": true,
        "outDir": "./dist",
        "types": [
            "node",
            "jest",
            "@testing-library/jest-dom"
        ],
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/types/*": [
                "./types/*"
            ]
        }
    },
    "include": [
        ".env.d.ts",
        "types/**/*.d.ts",
        "scripts/**/*.ts",
        "types/**/*.ts",
        "types/**/*.d.ts",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "src/**/*.tsx",
        "./src/**/*.ts",
    ],
    "exclude": [
        ".next",
        ".vercel",
        "assets",
        "certificates",
        "credits",
        "public",
        "node_modules",
        "packages"
    ]
}
